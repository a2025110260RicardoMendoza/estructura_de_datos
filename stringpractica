#include <iostream>
#include <string>

using namespace std;

string invertir(string &frase);
string quitarVocales(string &frase);
string intercambiar(string &frase, string buscar, string reemplazo);
string sacarSubstring(string frase, int ini, int cant);
int contarVocales(string frase);
string quitarEspacios(string &frase);
int encontrar(string frase, char c);

int main() {
    string cadena;
    int opcion;

    cout << "Ingrese la cadena inicial: ";
    getline(cin, cadena);

    do {
        cout << "\n--- MENU (Frase: [" << cadena << "]) ---" << endl;
        cout << "1. Invertir frase" << endl;
        cout << "2. Quitar vocales" << endl;
        cout << "3. Intercambiar palabras" << endl;
        cout << "4. Sacar substring" << endl;
        cout << "5. Contar vocales" << endl;
        cout << "6. Quitar espacios" << endl;
        cout << "7. Encontrar caracter" << endl;
        cout << "8. Longitud" << endl;
        cout << "9. Comparar" << endl;
        cout << "0. Salir" << endl;
        cout << "Seleccione: ";
        cin >> opcion;
        cin.ignore();

        switch (opcion) {
            case 1: 
                cout << "Resultado: " << invertir(cadena) << endl; 
                break;
            case 2: 
                cout << "Resultado: " << quitarVocales(cadena) << endl; 
                break;
            case 3: {
                string b, r;
                cout << "Buscar: "; cin >> b;
                cout << "Reemplazo: "; cin >> r;
                cout << "Resultado: " << intercambiar(cadena, b, r) << endl;
                break;
            }
            case 4: {
                int p, c;
                cout << "Posicion y cantidad: "; cin >> p >> c;
                cout << "Resultado: " << sacarSubstring(cadena, p, c) << endl;
                break;
            }
            case 5: 
                cout << "Total vocales: " << contarVocales(cadena) << endl; 
                break;
            case 6: 
                cout << "Resultado: " << quitarEspacios(cadena) << endl; 
                break;
            case 7: {
                char car;
                cout << "Caracter: "; cin >> car;
                int pos = encontrar(cadena, car);
                if (pos != -1) cout << "Posicion: " << pos << endl;
                else cout << "No encontrado" << endl;
                break;
            }
            case 8: 
                cout << "Longitud: " << cadena.length() << endl; 
                break;
            case 9: {
                string otra;
                cout << "Comparar con: "; getline(cin, otra);
                if (cadena == otra) cout << "Iguales" << endl;
                else cout << "Diferentes" << endl;
                break;
            }
        }
    } while (opcion != 0);

    return 0;
}

string invertir(string &frase) {
    string aux = "";
    for (int i = frase.length() - 1; i >= 0; i--) {
        aux += frase[i];
    }
    frase = aux;
    return frase;
}

string quitarVocales(string &frase) {
    string aux = "";
    for (int i = 0; i < frase.length(); i++) {
        char c = frase[i];
        if (c != 'a' && c != 'e' && c != 'i' && c != 'o' && c != 'u' &&
            c != 'A' && c != 'E' && c != 'I' && c != 'O' && c != 'U') {
            aux += c;
        }
    }
    frase = aux;
    return frase;
}

string intercambiar(string &frase, string buscar, string reemplazo) {
    size_t pos = frase.find(buscar);
    if (pos != string::npos) {
        frase.replace(pos, buscar.length(), reemplazo);
    }
    return frase;
}

string sacarSubstring(string frase, int ini, int cant) {
    if (ini < frase.length()) {
        return frase.substr(ini, cant);
    }
    return "Error";
}

int contarVocales(string frase) {
    int contador = 0;
    for (int i = 0; i < frase.length(); i++) {
        char c = frase[i];
        if (c == 'a' || c == 'e' || c == 'i' || c == 'o' || c == 'u' ||
            c == 'A' || c == 'E' || c == 'I' || c == 'O' || c == 'U') {
            contador++;
        }
    }
    return contador;
}

string quitarEspacios(string &frase) {
    string aux = "";
    for (int i = 0; i < frase.length(); i++) {
        if (frase[i] != ' ') aux += frase[i];
    }
    frase = aux;
    return frase;
}

int encontrar(string frase, char c) {
    size_t pos = frase.find(c);
    if (pos != string::npos) return (int)pos;
    return -1;
}
